{
  "manifest_version": 3,
  "name": "Open Brain",
  "version": "2.0.0",
  "description": "Your cross-AI memory layer. Works with Gemini, ChatGPT, Perplexity, Grok, Claude, and more.",
  "permissions": ["storage", "clipboardWrite"],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*",
        "https://grok.com/*",
        "https://x.com/i/grok*",
        "https://claude.ai/*",
        "https://chat.deepseek.com/*",
        "https://chat.mistral.ai/*",
        "https://copilot.microsoft.com/*",
        "https://poe.com/*"
      ],
      "js": ["services.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
